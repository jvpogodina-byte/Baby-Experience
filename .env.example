# Required for the current MVP.
# PostgreSQL. Use Neon with sslmode=require in production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/babyexperience"

# Required for the current MVP because /admin uses NextAuth.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-me-with-a-long-random-secret"

# Required when running prisma:seed to create the first MVP admin.
# These are not needed at Next.js runtime, but are needed in the seed shell.
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Optional for the current MVP.
# Set in Vercel only if admin image upload must use Vercel Blob in production.
# Without it, the public site and manual imageUrl fields still work.
BLOB_READ_WRITE_TOKEN=""

# Reserved for the next public user release.
# Current MVP disables social login via feature flags, so these are not required.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
